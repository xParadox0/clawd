# ── Anthropic API (required for auto-reply) ───────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: customize the assistant personality ─────────────────────────────
# CLAWD_SYSTEM_PROMPT=You are a helpful assistant named Clawd. Reply concisely.

# ── Optional: how often to check for new messages (ms, default 2000) ─────────
# CLAWD_POLL_MS=2000

# ── Telegram bot token from @BotFather ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── WebChat port (default 18790) ─────────────────────────────────────────────
WEBCHAT_PORT=18790

# ── Data directory (default: C:\Users\<you>\.clawd) ──────────────────────────
# CLAWD_DATA_DIR=C:\Users\yonas\.clawd
