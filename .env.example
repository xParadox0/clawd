# ── Auto-reply ─────────────────────────────────────────────────────────────────
# No API key needed! Clawd uses your claude.ai OAuth token automatically.
# (from ~/.claude/.credentials.json — same login as Claude Desktop / Claude Code)
#
# Optionally set an explicit Anthropic API key to override the OAuth token:
# ANTHROPIC_API_KEY=sk-ant-...

# ── Assistant personality ──────────────────────────────────────────────────────
# Customize how Clawd introduces itself and what it says it can do.
# Default is set in .env — edit it to change behaviour without rebuilding.
CLAWD_SYSTEM_PROMPT=You are Clawd, a personal AI assistant gateway running on the user's own computer. You have full access to their WhatsApp, Telegram, and WebChat channels and can read and send messages on their behalf. You are similar to OpenClaw — a self-hosted personal AI agent. Reply concisely and naturally. Support Bahasa Indonesia and English — always reply in the same language the user writes in.

# ── Telegram ───────────────────────────────────────────────────────────────────
# Get a token from @BotFather on Telegram, then paste it here.
TELEGRAM_BOT_TOKEN=

# ── WebChat port (default 18790) ───────────────────────────────────────────────
WEBCHAT_PORT=18790

# ── Data directory (default: C:\Users\<you>\.clawd) ───────────────────────────
# CLAWD_DATA_DIR=C:\Users\yonas\.clawd

# ── Admin API port (default 18791) ────────────────────────────────────────────
# ADMIN_PORT=18791
